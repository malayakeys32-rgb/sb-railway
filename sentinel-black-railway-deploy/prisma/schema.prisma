generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  password        String
  name            String
  role            Role            @default(REPORTER)
  maskedMode      Boolean         @default(false)
  mfaEnabled      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  incidents       Incident[]
  evidence        Evidence[]
  auditLogs       AuditLog[]
  sharedLinks     SharedLink[]
  missions        Mission[]
  missionLogs     MissionLog[]
  teamAssignments TeamMember[]

  @@map("users")
}

model Incident {
  id              String          @id @default(cuid())
  title           String
  description     String
  severity        Severity        @default(LOW)
  status          IncidentStatus  @default(OPEN)
  category        String?
  location        String?
  occurredAt      DateTime
  resolvedAt      DateTime?
  isAnonymous     Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  reporterId      String
  reporter        User            @relation(fields: [reporterId], references: [id])
  timeline        TimelineEvent[]
  evidence        Evidence[]
  patterns        PatternLink[]

  @@map("incidents")
}

model Evidence {
  id              String          @id @default(cuid())
  filename        String
  originalName    String
  mimeType        String
  fileSize        Int
  fileHash        String
  storagePath     String
  description     String?
  takenAt         DateTime?
  chainOfCustody  Json            @default("[]")
  isSealed        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  uploaderId      String
  uploader        User            @relation(fields: [uploaderId], references: [id])
  incidentId      String?
  incident        Incident?       @relation(fields: [incidentId], references: [id])
  sharedLinks     SharedLink[]

  @@map("evidence")
}

model TimelineEvent {
  id              String          @id @default(cuid())
  incidentId      String
  incident        Incident        @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  eventAt         DateTime
  description     String
  actor           String?
  isLocked        Boolean         @default(true)
  forensicHash    String?
  createdAt       DateTime        @default(now())

  @@map("timeline_events")
}

model Pattern {
  id              String          @id @default(cuid())
  title           String
  description     String
  detectedAt      DateTime        @default(now())
  severity        Severity        @default(LOW)
  frequency       Int             @default(1)
  isEscalating    Boolean         @default(false)
  incidents       PatternLink[]
  createdAt       DateTime        @default(now())

  @@map("patterns")
}

model PatternLink {
  id          String   @id @default(cuid())
  patternId   String
  incidentId  String
  pattern     Pattern  @relation(fields: [patternId], references: [id], onDelete: Cascade)
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@unique([patternId, incidentId])
  @@map("pattern_links")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  resource    String
  resourceId  String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model SharedLink {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  evidenceId  String?
  evidence    Evidence? @relation(fields: [evidenceId], references: [id])
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  expiresAt   DateTime?
  maxViews    Int?
  viewCount   Int       @default(0)
  isRevoked   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("shared_links")
}

model Mission {
  id                    String          @id @default(cuid())
  title                 String
  description           String?
  progressPercent       Int             @default(0)
  status                MissionStatus   @default(ACTIVE)
  missionDate           DateTime        @default(now())
  createdById           String
  createdBy             User            @relation(fields: [createdById], references: [id])
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  tasks                 MissionTask[]
  timeline              MissionTimeline[]
  logs                  MissionLog[]
  teamMembers           TeamMember[]
  readinessScores       ReadinessScore?

  @@map("missions")
}

model MissionTask {
  id          String          @id @default(cuid())
  missionId   String
  mission     Mission         @relation(fields: [missionId], references: [id], onDelete: Cascade)
  title       String
  description String?
  priority    TaskPriority    @default(MEDIUM)
  status      TaskStatus      @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("mission_tasks")
}

model MissionTimeline {
  id          String   @id @default(cuid())
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  time        String
  event       String
  createdAt   DateTime @default(now())

  @@map("mission_timeline")
}

model MissionLog {
  id          String   @id @default(cuid())
  missionId   String
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  note        String
  timestamp   String
  mediaUrl    String?
  mediaType   String?
  createdAt   DateTime @default(now())

  @@map("mission_logs")
}

model TeamMember {
  id          String          @id @default(cuid())
  missionId   String
  mission     Mission         @relation(fields: [missionId], references: [id], onDelete: Cascade)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  task        String
  status      TeamMemberStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([missionId, userId])
  @@map("team_members")
}

model ReadinessScore {
  id          String   @id @default(cuid())
  missionId   String   @unique
  mission     Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  planning    Int      @default(0)
  staffing    Int      @default(0)
  logistics   Int      @default(0)
  safety      Int      @default(0)
  budget      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("readiness_scores")
}

enum Role {
  ADMIN
  REPORTER
  VIEWER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum MissionStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum TeamMemberStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

