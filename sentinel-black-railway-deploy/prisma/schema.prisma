generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  password        String
  name            String
  role            Role            @default(REPORTER)
  maskedMode      Boolean         @default(false)
  mfaEnabled      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  incidents       Incident[]
  evidence        Evidence[]
  auditLogs       AuditLog[]
  sharedLinks     SharedLink[]

  @@map("users")
}

model Incident {
  id              String          @id @default(cuid())
  title           String
  description     String
  severity        Severity        @default(LOW)
  status          IncidentStatus  @default(OPEN)
  category        String?
  location        String?
  occurredAt      DateTime
  resolvedAt      DateTime?
  isAnonymous     Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  reporterId      String
  reporter        User            @relation(fields: [reporterId], references: [id])
  timeline        TimelineEvent[]
  evidence        Evidence[]
  patterns        PatternLink[]

  @@map("incidents")
}

model Evidence {
  id              String          @id @default(cuid())
  filename        String
  originalName    String
  mimeType        String
  fileSize        Int
  fileHash        String
  storagePath     String
  description     String?
  takenAt         DateTime?
  chainOfCustody  Json            @default("[]")
  isSealed        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  uploaderId      String
  uploader        User            @relation(fields: [uploaderId], references: [id])
  incidentId      String?
  incident        Incident?       @relation(fields: [incidentId], references: [id])
  sharedLinks     SharedLink[]

  @@map("evidence")
}

model TimelineEvent {
  id              String          @id @default(cuid())
  incidentId      String
  incident        Incident        @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  eventAt         DateTime
  description     String
  actor           String?
  isLocked        Boolean         @default(true)
  forensicHash    String?
  createdAt       DateTime        @default(now())

  @@map("timeline_events")
}

model Pattern {
  id              String          @id @default(cuid())
  title           String
  description     String
  detectedAt      DateTime        @default(now())
  severity        Severity        @default(LOW)
  frequency       Int             @default(1)
  isEscalating    Boolean         @default(false)
  incidents       PatternLink[]
  createdAt       DateTime        @default(now())

  @@map("patterns")
}

model PatternLink {
  id          String   @id @default(cuid())
  patternId   String
  incidentId  String
  pattern     Pattern  @relation(fields: [patternId], references: [id], onDelete: Cascade)
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@unique([patternId, incidentId])
  @@map("pattern_links")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  resource    String
  resourceId  String?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model SharedLink {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  evidenceId  String?
  evidence    Evidence? @relation(fields: [evidenceId], references: [id])
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  expiresAt   DateTime?
  maxViews    Int?
  viewCount   Int       @default(0)
  isRevoked   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("shared_links")
}

enum Role {
  ADMIN
  REPORTER
  VIEWER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}
